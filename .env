NODE_ENV=development
PORT=5000

# When true, POST /businesses/billing/pay-invoice records settlement in Postgres without a card processor (dev only).
BILLING_SIMULATION_MODE=true
POSTGRES_USER=postgres
POSTGRES_DB=arorixOS
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=root
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/arorixOS?schema=public"

# Optional: receive new support tickets & call requests via Resend (requires RESEND_API_KEY).
# SUPPORT_INBOX_EMAIL=you@yourcompany.com

# Transactional email (Resend — https://resend.com). If unset, invite tokens are returned in the API for manual sharing.
# RESEND_API_KEY=re_xxxxxxxx
# Verified domain from address (production). For Resend quick tests you can use: Arorix OS <onboarding@resend.dev>
# EMAIL_FROM=Arorix OS <onboarding@resend.dev>
# Public URL of the OS (used in invite links). Match your Vite dev port.
# APP_PUBLIC_URL=http://localhost:8081
