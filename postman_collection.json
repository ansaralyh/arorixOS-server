{
  "info": {
    "_postman_id": "b1a13b65-e9cc-4d37-8f7d-0a8a7a00f1c3",
    "name": "Arorix OS Backend API",
    "description": "API collection for the Arorix OS backend. Includes Authentication, Business Management, and Onboarding flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "health"
          ]
        },
        "description": "Basic health check to ensure the server is running."
      },
      "response": []
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register (New User & Business)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"securepassword123\",\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"businessName\": \"Acme Corp\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Creates a new User, a new Business, links them as the OWNER, and returns a JWT token."
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Authenticates a user and returns their JWT token and primary business details."
          },
          "response": []
        },
        {
          "name": "Accept team invite",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{invite_token}}\",\n  \"password\": \"securepassword123\",\n  \"firstName\": \"Sam\",\n  \"lastName\": \"Invited\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/accept-invite",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "accept-invite"]
            },
            "description": "Public. Use inviteToken from POST /businesses/invitations. New users need firstName/lastName; existing users omit names and use their password."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Businesses",
      "item": [
        {
          "name": "GET Members (teammates)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/businesses/members",
              "host": ["{{base_url}}"],
              "path": ["api", "businesses", "members"]
            },
            "description": "Requires JWT with businessId. Verifies business_members row. Lists joined users for the workspace."
          },
          "response": []
        },
        {
          "name": "GET Invitations (pending)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/businesses/invitations",
              "host": ["{{base_url}}"],
              "path": ["api", "businesses", "invitations"]
            },
            "description": "Requires JWT with businessId. Lists PENDING business_invitations only (no token hashes)."
          },
          "response": []
        },
        {
          "name": "POST Invitation (admin/owner)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newmember@example.com\",\n  \"role\": \"MEMBER\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/businesses/invitations",
              "host": ["{{base_url}}"],
              "path": ["api", "businesses", "invitations"]
            },
            "description": "OWNER or ADMIN only. Returns inviteToken once — set Postman variable invite_token from response."
          },
          "response": []
        },
        {
          "name": "POST Invitation resend",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/businesses/invitations/{{invite_id}}/resend",
              "host": ["{{base_url}}"],
              "path": ["api", "businesses", "invitations", "{{invite_id}}", "resend"]
            },
            "description": "OWNER or ADMIN. Regenerates token and expiry; emails when Resend is configured."
          },
          "response": []
        },
        {
          "name": "DELETE Invitation (revoke)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/businesses/invitations/{{invite_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "businesses", "invitations", "{{invite_id}}"]
            },
            "description": "OWNER or ADMIN. Revokes a PENDING invite by id."
          },
          "response": []
        },
        {
          "name": "PATCH Member role",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"MANAGER\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/businesses/members/{{membership_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "businesses", "members", "{{membership_id}}"]
            },
            "description": "OWNER or ADMIN. Cannot change OWNER row. role ∈ ADMIN, MANAGER, MEMBER."
          },
          "response": []
        },
        {
          "name": "DELETE Member",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/businesses/members/{{membership_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "businesses", "members", "{{membership_id}}"]
            },
            "description": "OWNER or ADMIN. Cannot remove OWNER."
          },
          "response": []
        },
        {
          "name": "GET Formation requests (my business)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/businesses/formation-requests",
              "host": ["{{base_url}}"],
              "path": ["api", "businesses", "formation-requests"]
            },
            "description": "Requires JWT. Returns formation_requests for the token's business, newest first."
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Automatically set the JWT token as an environment variable if login/register is successful",
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "    var jsonData = pm.response.json();",
          "    if (jsonData.data && jsonData.data.token) {",
          "        pm.environment.set(\"jwt_token\", jsonData.data.token);",
          "    }",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ]
}